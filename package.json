{
  "name": "pluck",
  "version": "0.0.1",
  "private": true,
  "description": "Pluck — AI-powered visual web scraper. Click anything, get structured data.",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:extension": "pnpm --filter @pluck/extension dev",
    "dev:web": "pnpm --filter @pluck/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "gen-license-keys": "tsx scripts/gen-license-keys.ts",
    "sign-test-license": "tsx scripts/sign-test-license.ts",
    "test-ipn": "tsx scripts/test-ipn.ts",
    "gen-icons": "tsx scripts/gen-icons.ts",
    "gen-screenshots": "tsx scripts/gen-screenshots.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
